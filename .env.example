# Kopioi .env.example -> .env. Älä commitoi salaisuuksia.
# npm start / server.js: Atlas URI (album_db_test tai oma testikanta).
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.nhame0v.mongodb.net/album_db_test?retryWrites=true&w=majority&appName=Cluster0
PORT=3001

# Jest (npm test): oletuksena käytetään paikallista mongodb-memory-serveriä (ei vaadi Atlasia).
# Halutessasi testit suoraan Atlasiin: JEST_USE_ATLAS=1 ja kelvollinen MONGO_URI yllä.
# JEST_USE_ATLAS=1
